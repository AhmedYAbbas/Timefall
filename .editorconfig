# Timefall engine — editor defaults for file types .clang-format doesn't cover
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# C++ / shaders — tabs, width 4 (matches .clang-format)
[*.{cpp,h,hpp,c,inl,glsl}]
indent_style = tab
indent_size = 4

# C# script core — 4 spaces
[*.cs]
indent_style = space
indent_size = 4

# premake build scripts — tabs
[*.lua]
indent_style = tab
indent_size = 4

# engine YAML assets (scenes, materials, projects) — 2 spaces
[*.{yml,yaml,timefall,tfmat,tfproj,tfr}]
indent_style = space
indent_size = 2

# markdown: trailing double-space is a hard line break
[*.md]
trim_trailing_whitespace = false
